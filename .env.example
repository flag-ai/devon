# DEVON configuration — copy to .env and edit.

# --- Required ---
DATABASE_URL=postgres://devon:devon@localhost:5432/devon?sslmode=disable

# --- Server ---
LISTEN_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# --- Auth ---
# Leave empty for un-provisioned install — hit POST /api/v1/setup to generate.
DEVON_ADMIN_TOKEN=

# --- External services ---
# Optional HF token for authenticated calls (higher rate limits, gated models).
HF_TOKEN=

# --- Frontend ---
# Comma-separated list of allowed CORS origins. Empty means same-origin only.
DEVON_CORS_ORIGINS=
# Optional CSP frame-ancestors override when embedded in a parent dashboard.
DEVON_FRAME_ANCESTORS=
